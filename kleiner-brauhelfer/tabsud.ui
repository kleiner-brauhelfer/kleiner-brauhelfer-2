                 </widget>
                </item>
                <item>
                 <widget class="DoubleSpinBox" name="tbWasserVerschneidungSW">
                  <property name="minimumSize">
                   <size>
                    <width>50</width>
                    <height>0</height>
                   </size>
                  </property>
                  <property name="alignment">
                   <set>Qt::AlignCenter</set>
                  </property>
