               <property name="orientation">
                <enum>Qt::Horizontal</enum>
               </property>
              </widget>
             </item>
             <item row="2" column="7">
              <widget class="QLabel" name="lblGruenschlauchzeitpunktEinheit">
               <property name="text">
                <string notr="true">°P</string>
               </property>
